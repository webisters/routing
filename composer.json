{
    "name": "webisters/routing",
    "description": "Webisters Routing Library",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "routing",
        "router",
        "resource",
        "presenter",
        "rest",
        "restful"
    ],
    "authors": [
        {
            "name": "Hafiz Muhammad Moaz",
            "email": "hafizmoazkhalid@gmail.com",
            "homepage": "https://github.com/HafizMMoaz"
        }
    ],
    "homepage": "https://webisters.com/packages/routing",
    "support": {
        "email": "support@webisters.com",
        "issues": "https://github.com/webisters/routing/issues",
        "forum": "https://github.com/webisters/forum",
        "source": "https://github.com/webisters/routing",
        "docs": "https://webisters.com"
    },
    "funding": [
        {
            "type": "Webisters Sponsor",
            "url": "https://webisters.com/sponsor"
        }
    ],
    "require": {
        "php": ">=8.2",
        "webisters/debug": "*",
        "webisters/http": "*",
        "webisters/language": "*"
    },
    "require-dev": {
        "webisters/coding-standard": "*",
        "jetbrains/phpstorm-attributes": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Framework\\Routing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Routing\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}


